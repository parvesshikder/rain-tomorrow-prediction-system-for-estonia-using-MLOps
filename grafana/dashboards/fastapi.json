{
  "title": "FastAPI Monitoring",
  "timezone": "browser",
  "panels": [
    {
      "title": "Total API Requests / Minute",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) * 60",
          "legendFormat": "Requests per min",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Average Request Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_request_duration_seconds_sum[1m]) / rate(http_request_duration_seconds_count[1m])",
          "legendFormat": "Latency (s)",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 36,
  "version": 1
}
